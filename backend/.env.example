# Use either OpenAI or Anthropic. If both are set, OpenAI takes precedence.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional - defaults to gpt-4o-mini / claude-haiku
LLM_MODEL=

DATABASE_URL=sqlite:///./traqcheck.db
UPLOAD_DIR=./uploads

# Email transport (optional). Without any of these, requests are only logged.
# Two supported transports - SMTP takes precedence when both are configured.

# Gmail SMTP. Use a 16-char app password from myaccount.google.com/apppasswords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Resend (only delivers to the account-holder email until you verify a domain).
RESEND_API_KEY=
RESEND_FROM=
